+  // 概念
+  shield:   "M12 3.8c2.6 1.4 5 2 7 2.2 0 6.6-2.4 11.4-7 14.2-4.6-2.8-7-7.6-7-14.2 2-.2 4.4-.8 7-2.2Z M9 11.6l2.2 2.2 3.8-4",
