{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pptx-creation/schemas/deck_plan.schema.json",
  "title": "Deck plan",
  "description": "The engine's input: an ordered list of slides, each naming a pattern from references/patterns/catalog.md plus that pattern's content slots. deck-strategy produces this; bin/generate.js consumes it. Accepts either a bare slides array or an object with deck-level meta.",
  "oneOf": [
    { "$ref": "#/definitions/slideArray" },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["slides"],
      "properties": {
        "meta": { "$ref": "#/definitions/meta" },
        "slides": { "$ref": "#/definitions/slideArray" }
      }
    }
  ],
  "definitions": {
    "meta": {
      "type": "object",
      "description": "Deck-level metadata and chrome.",
      "additionalProperties": false,
      "properties": {
        "title":  { "type": "string", "description": "PPTX title metadata." },
        "author": { "type": "string", "description": "PPTX author metadata." },
        "footerLabel": {
          "type": "string",
          "description": "Bottom-left brand label on body slides. Overrides theme.brand.footerLabel. Empty string = no label."
        },
        "showPageNumbers": {
          "type": "boolean",
          "default": true,
          "description": "Show the page number at bottom-right of body slides."
        }
      }
    },
    "slideArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/slide" }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "content"],
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Pattern id. Must exist in the engine registry.",
          "enum": ["cover", "message", "two-column", "comparison", "chart", "stat-grid", "table", "section", "cta", "flow", "cycle", "matrix", "timeline", "steps", "branch", "formula", "card-grid", "waterfall"]
        },
        "content": {
          "type": "object",
          "description": "Pattern-specific slots (see catalog.md). All patterns accept an optional 'notes' (speaker notes). Validated per-pattern below.",
          "properties": {
            "notes": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "pattern": { "const": "cover" } } },
          "then": { "properties": { "content": {
            "required": ["titleLines"],
            "properties": {
              "kicker": { "type": "string" },
              "titleLines": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 2 },
              "subtitle": { "type": "string" },
              "footer": { "type": "string" },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "message" } } },
          "then": { "properties": { "content": {
            "required": ["messageLines"],
            "properties": {
              "kicker": { "type": "string" },
              "messageLines": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 2 },
              "statBig": { "type": "string" },
              "statCaption": { "type": ["string", "array"], "items": { "type": "string" }, "description": "Sub-caption under the big stat. A string auto-wraps; an array of strings is rendered as author-controlled lines (manual kinsoku control until the line-break engine lands)." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "two-column" } } },
          "then": { "properties": { "content": {
            "required": ["title", "items"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "lead": { "type": "string" },
              "items": {
                "type": "array", "minItems": 1, "maxItems": 4,
                "items": {
                  "type": "object",
                  "required": ["n", "head", "body"],
                  "additionalProperties": false,
                  "properties": {
                    "n": { "type": ["integer", "string"] },
                    "head": { "type": "string" },
                    "body": { "type": "string" }
                  }
                }
              },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "comparison" } } },
          "then": { "properties": { "content": {
            "required": ["title", "left", "right"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "left": { "$ref": "#/definitions/comparisonColumn" },
              "right": { "$ref": "#/definitions/comparisonColumn" },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "flow" } } },
          "then": { "properties": { "content": {
            "required": ["steps"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "steps": { "type": "array", "items": { "type": ["string", "array"] }, "minItems": 3, "maxItems": 6, "description": "3-6 step labels (native text); the engine draws the arrow-connected nodes." },
              "direction": { "type": "string", "enum": ["horizontal", "vertical"] },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "cycle" } } },
          "then": { "properties": { "content": {
            "required": ["steps"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "steps": { "type": "array", "items": { "type": ["string", "array"] }, "minItems": 3, "maxItems": 6, "description": "3-6 node labels (native text) placed on a ring; the engine draws the cyclic arrows." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "matrix" } } },
          "then": { "properties": { "content": {
            "required": ["quadrants"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "axisX": { "type": "array", "items": { "type": ["string", "array"] }, "maxItems": 2, "description": "X-axis end labels [left, right], shown top." },
              "axisY": { "type": "array", "items": { "type": ["string", "array"] }, "maxItems": 2, "description": "Y-axis end labels [top, bottom], shown left." },
              "emphasizeIndex": { "type": "integer", "minimum": 0, "maximum": 3, "description": "Tint one quadrant (0=TL,1=TR,2=BL,3=BR)." },
              "quadrants": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "object", "properties": { "head": { "type": "string" }, "body": { "type": ["string", "array"] } } }, "description": "Exactly 4 quadrants (TL, TR, BL, BR), each {head?, body?}." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "waterfall" } } },
          "then": { "properties": { "content": {
            "required": ["items"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "items": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "type": "object", "required": ["label", "value"], "properties": { "label": { "type": ["string", "array"], "description": "Category label under the bar (short; the band is height-gated)." }, "value": { "type": "number", "description": "total:true -> the absolute LEVEL; otherwise the signed delta (negatives render as ▲)." }, "total": { "type": "boolean", "description": "Anchor bar drawn from zero (start / subtotal / end)." } } }, "description": "3-8 bridge items: levels (total:true) and signed drivers between them." },
              "unit": { "type": "string", "description": "Shown once bottom-left (単位：…)." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "card-grid" } } },
          "then": { "properties": { "content": {
            "required": ["cards"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "cards": { "type": "array", "minItems": 4, "maxItems": 6, "items": { "type": "object", "required": ["head"], "properties": { "head": { "type": ["string", "array"], "description": "Short term (one line — a wrapping head is a hard overflow)." }, "body": { "type": ["string", "array"], "description": "One short explanation (<=3 lines)." } } }, "description": "4-6 head+body cards laid out in two rows." },
              "emphasizeIndex": { "type": "integer", "minimum": 0, "maximum": 5, "description": "Tint one card (row-major index)." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "formula" } } },
          "then": { "properties": { "content": {
            "required": ["operands"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "result": { "type": ["string", "array"], "description": "Optional result box (tinted), drawn first with an = between it and the operands." },
              "operands": { "type": "array", "items": { "type": ["string", "array"] }, "minItems": 2, "maxItems": 4, "description": "2-4 factor/summand labels joined by the operator glyph." },
              "operator": { "type": "string", "enum": ["×", "+"], "description": "Glyph drawn between operands (default ×)." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "branch" } } },
          "then": { "properties": { "content": {
            "required": ["source", "branches"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "source": { "type": ["string", "array"], "description": "The single anchor node (tinted): the source in diverge, the result in converge." },
              "branches": { "type": "array", "items": { "type": ["string", "array"] }, "minItems": 2, "maxItems": 4, "description": "2-4 branch labels; the engine stacks them and fans the arrows." },
              "direction": { "type": "string", "enum": ["diverge", "converge"], "description": "diverge (default): 1 source -> N branches. converge: N branches -> 1 result." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "steps" } } },
          "then": { "properties": { "content": {
            "required": ["steps"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "steps": { "type": "array", "items": { "type": ["string", "array"] }, "minItems": 3, "maxItems": 5, "description": "3-5 ascending stage labels (native text); the engine draws the staircase blocks, tinting the last (goal) block." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "timeline" } } },
          "then": { "properties": { "content": {
            "required": ["milestones"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "milestones": { "type": "array", "minItems": 3, "maxItems": 7, "items": { "type": "object", "required": ["date", "label"], "properties": { "date": { "type": ["string", "array"], "description": "Short date/year (e.g. 2014.10) — one line; the height gate rejects a wrapping date." }, "label": { "type": ["string", "array"], "description": "What happened — short; baked (kinsoku) and height-gated per milestone." } } }, "description": "3-7 dated milestones drawn on the horizontal spine, alternating above/below." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "chart" } } },
          "then": { "properties": { "content": {
            "required": ["title", "series", "takeawayHead", "takeaway"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "series": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["name", "labels", "values"],
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string" },
                      "labels": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
                      "values": { "type": "array", "items": { "type": "number" }, "minItems": 2 }
                    }
                  },
                  {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 4,
                    "description": "band (帯グラフ) only: 2-4 segments; first segment's labels are the 1-5 category rows.",
                    "items": {
                      "type": "object",
                      "required": ["name", "values"],
                      "additionalProperties": false,
                      "properties": {
                        "name": { "type": "string" },
                        "labels": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 5 },
                        "values": { "type": "array", "items": { "type": "number" }, "minItems": 1 }
                      }
                    }
                  }
                ]
              },
              "takeawayHead": { "type": "string" },
              "takeaway": { "type": "string" },
              "chartType": { "type": "string", "enum": ["column", "bar", "line", "pie", "doughnut", "band"], "description": "column (default) = categories/few periods; bar = ranking with long labels; line = continuous trend; pie/doughnut = parts of ONE whole, max 5 slices; band = 100% stacked composition (series becomes an ARRAY of 2-4 segments)." },
              "unit": { "type": "string", "description": "Shown once top-left (単位：…), never on every bar." },
              "valueFormat": { "type": "string", "description": "Explicit data-label format code (overrides auto #,##0 / #,##0.0)." },
              "emphasizeIndex": { "type": "integer", "minimum": 0, "description": "Colour ONE bar/slice accentDeep and mute the rest." },
              "targetLine": { "type": "object", "required": ["value"], "properties": { "value": { "type": "number" }, "label": { "type": "string" } }, "description": "Dashed reference line over the columns (前年 / 目標)." },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "stat-grid" } } },
          "then": { "properties": { "content": {
            "required": ["title", "stats"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "stats": {
                "type": "array", "minItems": 2, "maxItems": 4,
                "items": {
                  "type": "object",
                  "required": ["value", "label"],
                  "additionalProperties": false,
                  "properties": {
                    "value": { "type": ["string", "number"] },
                    "label": { "type": "string" },
                    "sub": { "type": "string" }
                  }
                }
              },
              "emphasizeIndex": { "type": "integer", "minimum": 0 },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "table" } } },
          "then": { "properties": { "content": {
            "required": ["title", "columns", "rows"],
            "properties": {
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "columns": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 6 },
              "rows": {
                "type": "array", "minItems": 1,
                "items": { "type": "array", "items": { "type": ["string", "number"] } }
              },
              "colAlign": { "type": "array", "items": { "type": "string", "enum": ["left", "right", "center"] } },
              "colW": { "type": "array", "items": { "type": "number" } },
              "note": { "type": "string" },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "section" } } },
          "then": { "properties": { "content": {
            "required": ["title"],
            "properties": {
              "index": { "type": ["string", "number"] },
              "kicker": { "type": "string" },
              "title": { "type": ["string", "array"], "items": { "type": "string" } },
              "subtitle": { "type": "string" },
              "notes": { "type": "string" }
            }
          } } }
        },
        {
          "if": { "properties": { "pattern": { "const": "cta" } } },
          "then": { "properties": { "content": {
            "required": ["titleLines", "offerHead", "offerBody"],
            "properties": {
              "kicker": { "type": "string" },
              "titleLines": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 2 },
              "offerHead": { "type": "string" },
              "offerBody": { "type": "string" },
              "contact": { "type": "string" },
              "notes": { "type": "string" }
            }
          } } }
        }
      ]
    },
    "comparisonColumn": {
      "type": "object",
      "required": ["label", "role", "points"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "role": { "type": "string" },
        "points": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 5 }
      }
    }
  }
}
